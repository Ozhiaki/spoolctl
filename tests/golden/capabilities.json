{
  "attempt_states": [
    "abandoned",
    "canceled",
    "failed",
    "running",
    "succeeded",
    "timed_out"
  ],
  "contract_policy": "additive under contract_version 1: consumers must tolerate new verbs, new enum members (states, events), and new exit codes reachable only via new verbs; a breaking change to an existing verb's data shape or exit mapping is what bumps contract_version",
  "contract_version": "1",
  "env": {
    "SPOOLCTL_DB": "queue database path (overridden by --db; default ./.spoolctl/queue.db)",
    "SPOOLCTL_TEST_HEARTBEAT_INTERVAL": "test-only: seconds between worker heartbeats (default 5)",
    "SPOOLCTL_TEST_REAP_THRESHOLD": "test-only: seconds of heartbeat staleness before a running job becomes a reap candidate (default 30)"
  },
  "error_codes": [
    "CONFLICT",
    "INTERNAL",
    "INVALID_INPUT",
    "LOCKED",
    "MISSING_REQUIRED",
    "NOT_FOUND",
    "SAFETY_BLOCK",
    "TIMEOUT",
    "UNKNOWN_COMMAND",
    "UNKNOWN_FLAG"
  ],
  "events": [
    "added",
    "canceled",
    "claimed",
    "dead",
    "failed",
    "reaped",
    "retried",
    "succeeded",
    "timed_out"
  ],
  "exit_codes": {
    "0": {
      "meaning": "success (including empty results)",
      "retryable": null
    },
    "1": {
      "meaning": "user-input-error",
      "retryable": false
    },
    "2": {
      "meaning": "safety-block (refused; a --force form may exist)",
      "retryable": false
    },
    "3": {
      "meaning": "tool-environment-error",
      "retryable": null
    },
    "4": {
      "meaning": "transient-failure (retry after a short delay)",
      "retryable": true
    },
    "5": {
      "meaning": "conflict (state changed underneath)",
      "retryable": false
    },
    "6": {
      "meaning": "job-outcome-failure (an awaited job ended non-success)",
      "note": "pairs with ok:true and empty errors[]; the tool call succeeded and the exit code carries the job outcome for shell use; envelope consumers key off data.all_succeeded, not the exit code",
      "retryable": false
    }
  },
  "job_states": [
    "canceled",
    "dead",
    "done",
    "failed",
    "queued",
    "running"
  ],
  "verbs": {
    "add": {
      "data_schema": "{job_id: int, state: 'queued'}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": 3,
          "flag": "--max-retries",
          "type": "int"
        },
        {
          "default": 300,
          "flag": "--timeout",
          "type": "int"
        },
        {
          "default": null,
          "flag": "-c",
          "type": "str"
        }
      ],
      "positionals": [
        {
          "name": "argv",
          "repeatable": true
        }
      ],
      "summary": "enqueue a command (argv form or -c shell string)"
    },
    "cancel": {
      "data_schema": "{job_id: int, state: 'canceled', was_running: bool}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": false,
          "flag": "--running",
          "type": "bool"
        }
      ],
      "positionals": [
        {
          "name": "id",
          "repeatable": false
        }
      ],
      "summary": "cancel a queued job; --running also stops a running one (killed by its owning worker within a heartbeat)"
    },
    "capabilities": {
      "data_schema": "{attempt_states, contract_policy, contract_version, env, error_codes, events, exit_codes, job_states, verbs}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        }
      ],
      "positionals": [],
      "summary": "this machine-readable contract"
    },
    "list": {
      "data_schema": "{count: int, jobs: [{id, argv, state, attempts, max_retries, timeout_seconds, created_at, started_at, finished_at, next_run_at, last_exit_code, last_error}]}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": 50,
          "flag": "--limit",
          "type": "int"
        },
        {
          "default": null,
          "flag": "--state",
          "type": "str"
        }
      ],
      "positionals": [],
      "summary": "enumerate jobs, newest first, optionally filtered by state"
    },
    "output": {
      "data_schema": "{attempt_no, attempt_state, attempts_total, job_id, streams: {stdout|stderr: {path, preview, preview_truncated, size_bytes}}} or {attempts: []}",
      "flags": [
        {
          "default": null,
          "flag": "--attempt",
          "type": "int"
        },
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": false,
          "flag": "--raw",
          "type": "bool"
        },
        {
          "choices": [
            "both",
            "stderr",
            "stdout"
          ],
          "default": "both",
          "flag": "--stream",
          "type": "str"
        }
      ],
      "positionals": [
        {
          "name": "id",
          "repeatable": false
        }
      ],
      "summary": "captured stdout/stderr for any attempt of a job"
    },
    "retry": {
      "data_schema": "{job_id: int, state: 'queued'}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--force",
          "type": "bool"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        }
      ],
      "positionals": [
        {
          "name": "id",
          "repeatable": false
        }
      ],
      "summary": "requeue a dead or failed job with a fresh retry budget"
    },
    "show": {
      "data_schema": "{job: {id, argv, state, attempts, max_retries, timeout_seconds, created_at, started_at, finished_at, next_run_at, locked_by, locked_pid, locked_at, heartbeat_at, last_exit_code, last_error}, attempts: [{attempt_no, state, worker_id, worker_pid, started_at, finished_at, exit_code, error, stdout_path, stderr_path}], events: [{at, event, worker_id, detail}]}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        }
      ],
      "positionals": [
        {
          "name": "id",
          "repeatable": false
        }
      ],
      "summary": "one job in full detail: row, attempts, event trail"
    },
    "status": {
      "data_schema": "{counts: {canceled,dead,done,failed,queued,running}, recent_dead: [{id, command, attempts, last_error, finished_at, stdout_path, stderr_path}]}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": 10,
          "flag": "--limit",
          "type": "int"
        }
      ],
      "positionals": [],
      "summary": "queue counts and recent dead jobs; always exit 0"
    },
    "wait": {
      "data_schema": "{all_succeeded: bool, jobs: {'<id>': {state, attempts, last_exit_code, last_error}}}",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": 0.5,
          "flag": "--poll-interval",
          "type": "float"
        },
        {
          "default": null,
          "flag": "--timeout",
          "type": "float"
        }
      ],
      "positionals": [
        {
          "name": "ids",
          "repeatable": false
        }
      ],
      "summary": "block until every given job settles (done/dead/canceled); exit 0 all done, exit 6 any failed (envelope stays ok:true)"
    },
    "work": {
      "data_schema": "--once: {claimed: bool, job_id?, attempt_no?, result?, job_state?}; --drain: {drained: bool, executed: int}; loop mode writes nothing to stdout",
      "flags": [
        {
          "default": null,
          "flag": "--db",
          "type": "str"
        },
        {
          "default": false,
          "flag": "--drain",
          "type": "bool"
        },
        {
          "default": false,
          "flag": "--json",
          "type": "bool"
        },
        {
          "default": false,
          "flag": "--once",
          "type": "bool"
        },
        {
          "default": null,
          "flag": "--poll-interval",
          "type": "float"
        },
        {
          "default": null,
          "flag": "--worker-id",
          "type": "str"
        }
      ],
      "positionals": [],
      "summary": "run jobs until stopped; --once runs at most one; --drain runs until the queue settles"
    }
  }
}
